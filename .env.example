# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Amazon Bedrock Configuration
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# Amazon S3 Configuration (for report data storage)
S3_BUCKET_NAME=micropulse-data
S3_ENABLED=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: Database Configuration (if using)
# DATABASE_URL=postgresql://user:password@localhost:5432/micropulse

# Optional: Redis Configuration (if using)
# REDIS_URL=redis://localhost:6379

# Development/Production Mode
ENVIRONMENT=development
DEBUG=True
