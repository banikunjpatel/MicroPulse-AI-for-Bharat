DATABASE_URL=
NEXT_PUBLIC_APP_URL=
BETTER_AUTH_URL=
BETTER_AUTH_SECRET=

# Storage Configuration
# Set to "true" to use AWS S3, "false" to use local disk
S3_ENABLED=false

# S3 Configuration (used when S3_ENABLED=true)
S3_BUCKET_NAME=micropulse-data-lake
AW_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Local storage directory (used when S3_ENABLED=false)
UPLOAD_DIR=./uploads/sales

# LLM Provider Configuration
# Options: "openrouter", "bedrock", "mock"
LLM_PROVIDER=mock

# OpenRouter Configuration
OPENROUTER_API_KEY=
OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free

# AWS Bedrock Configuration
# Option 1: Use Bearer Token (simpler)
AW_BEARER_TOKEN_BEDROCK=
# Option 2: Use Access Keys
AWS_BEDROCK_ACCESS_KEY_ID=
AWS_BEDROCK_SECRET_ACCESS_KEY=
# Common settings
AW_BEDROCK_REGION=us-east-1
AW_BEDROCK_MODEL=amazon.nova-lite-v1:0

# Weather: Uses Open-Meteo (free, no API key required)
# News: Uses RSS feeds (free, no API key required)
# Festivals: Uses built-in static database